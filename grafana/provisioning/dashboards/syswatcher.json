{
  "title":         "SysWatcher",
  "uid":           "syswatcher-main",
  "version":       1,
  "schemaVersion": 38,
  "refresh":       "30s",
  "timezone":      "browser",
  "time":          { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name":       "server",
        "label":      "Server",
        "type":       "query",
        "datasource": { "type": "prometheus", "uid": "default" },
        "query":      "label_values(node_uname_info, server_name)",
        "refresh":    2,
        "sort":       1,
        "multi":      false,
        "includeAll": true,
        "allValue":   ".*"
      }
    ]
  },
  "panels": [
    {
      "id":    1,
      "title": "CPU Usage %",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit":  "percent",
          "min":   0,
          "max":   100,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 80   },
              { "color": "red",    "value": 95   }
            ]
          }
        }
      },
      "targets": [
        {
          "expr":         "100 - (avg by(server_name) (rate(node_cpu_seconds_total{mode=\"idle\", server_name=~\"$server\"}[5m])) * 100)",
          "legendFormat": "{{server_name}} CPU %",
          "refId":        "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id":    2,
      "title": "Memory Usage %",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit":  "percent",
          "min":   0,
          "max":   100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 80   },
              { "color": "red",    "value": 95   }
            ]
          }
        }
      },
      "targets": [
        {
          "expr":         "100 * (1 - node_memory_MemAvailable_bytes{server_name=~\"$server\"} / node_memory_MemTotal_bytes{server_name=~\"$server\"})",
          "legendFormat": "{{server_name}} Memory %",
          "refId":        "A"
        }
      ]
    },
    {
      "id":    3,
      "title": "Disk Usage % (all mounts)",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit":  "percent",
          "min":   0,
          "max":   100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 75   },
              { "color": "red",    "value": 90   }
            ]
          }
        }
      },
      "targets": [
        {
          "expr":         "100 - (node_filesystem_avail_bytes{server_name=~\"$server\", fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{server_name=~\"$server\", fstype!~\"tmpfs|overlay|squashfs\"} * 100)",
          "legendFormat": "{{server_name}} {{mountpoint}}",
          "refId":        "A"
        }
      ]
    },
    {
      "id":    4,
      "title": "Network rx/tx bytes/s",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit":  "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr":         "rate(node_network_receive_bytes_total{server_name=~\"$server\", device!~\"lo|docker.*|br.*\"}[5m])",
          "legendFormat": "{{server_name}} {{device}} rx",
          "refId":        "A"
        },
        {
          "expr":         "rate(node_network_transmit_bytes_total{server_name=~\"$server\", device!~\"lo|docker.*|br.*\"}[5m])",
          "legendFormat": "{{server_name}} {{device}} tx",
          "refId":        "B"
        }
      ]
    },
    {
      "id":    5,
      "title": "Load Average",
      "type":  "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit":  "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr":         "node_load1{server_name=~\"$server\"}",
          "legendFormat": "{{server_name}} 1m",
          "refId":        "A"
        },
        {
          "expr":         "node_load5{server_name=~\"$server\"}",
          "legendFormat": "{{server_name}} 5m",
          "refId":        "B"
        },
        {
          "expr":         "node_load15{server_name=~\"$server\"}",
          "legendFormat": "{{server_name}} 15m",
          "refId":        "C"
        }
      ]
    },
    {
      "id":    6,
      "title": "Current Stats",
      "type":  "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color":    { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 80   },
              { "color": "red",    "value": 95   }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation":   "auto",
        "textMode":      "auto",
        "colorMode":     "background"
      },
      "targets": [
        {
          "expr":         "100 - (avg by(server_name) (rate(node_cpu_seconds_total{mode=\"idle\", server_name=~\"$server\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId":        "A"
        },
        {
          "expr":         "100 * (1 - node_memory_MemAvailable_bytes{server_name=~\"$server\"} / node_memory_MemTotal_bytes{server_name=~\"$server\"})",
          "legendFormat": "Memory %",
          "refId":        "B"
        },
        {
          "expr":         "max(100 - (node_filesystem_avail_bytes{server_name=~\"$server\", mountpoint=\"/\"} / node_filesystem_size_bytes{server_name=~\"$server\", mountpoint=\"/\"} * 100))",
          "legendFormat": "Disk / %",
          "refId":        "C"
        },
        {
          "expr":         "node_load1{server_name=~\"$server\"}",
          "legendFormat": "Load 1m",
          "refId":        "D"
        }
      ]
    },
    {
      "id":    7,
      "title": "System Uptime",
      "type":  "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit":  "s",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode":      "auto",
        "colorMode":     "value"
      },
      "targets": [
        {
          "expr":         "time() - node_boot_time_seconds{server_name=~\"$server\"}",
          "legendFormat": "{{server_name}} uptime",
          "refId":        "A"
        }
      ]
    },
    {
      "id":    8,
      "title": "SysWatcher Events (annotations)",
      "type":  "text",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "options": {
        "mode":    "markdown",
        "content": "## SysWatcher Events\nAnnotations from the AI agent appear as markers on all time-series panels above.\n\n- **Green** = info sweep\n- **Yellow** = warn event detected\n- **Red** = critical event detected\n\nHover any annotation marker on the charts to see details."
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name":       "SysWatcher Events",
        "datasource": { "type": "grafana", "uid": "grafana" },
        "enable":     true,
        "hide":       false,
        "iconColor":  "rgba(255, 200, 0, 1)",
        "type":       "dashboard",
        "builtIn":    1
      }
    ]
  }
}
