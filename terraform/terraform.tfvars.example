# Copy to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

aws_region  = "us-east-1"
aws_profile = "default"          # your AWS CLI profile
project     = "syswatcher"
environment = "monitoring"

# Instance sizes
jump_instance_type = "t3.medium"   # 2 vCPU, 4GB RAM — runs Docker stack
dev_instance_type  = "t3.small"    # 2 vCPU, 2GB RAM
test_instance_type = "t3.small"

# Storage
jump_disk_gb = 30
dev_disk_gb  = 20
test_disk_gb = 20

# Network
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# Restrict SSH to your IP for security:
# allowed_ssh_cidr = "203.0.113.10/32"
allowed_ssh_cidr = "0.0.0.0/0"    # open — restrict in production
allowed_ui_cidr  = "0.0.0.0/0"
